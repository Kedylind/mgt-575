# Copy this file to ".env" and fill in real values. Never commit ".env".

# -----------------------------------------------------------------------------
# Default stack (recommended): one Google key, two model IDs
# -----------------------------------------------------------------------------
# Agents (transcript → style, slide images → descriptions / premise / arc /
# narrations): vision + text JSON via Gemini 2.5 Flash.
# TTS: Gemini speech generation (same API key, separate TTS model id).

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# Prebuilt voice name for Gemini TTS (see Google speech-generation docs)
TTS_VOICE=Kore

# -----------------------------------------------------------------------------
# Optional alternate stack (only if you implement OpenAI instead of Gemini)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy

# -----------------------------------------------------------------------------
# Input paths (defaults for run_lecture_pipeline.py)
# -----------------------------------------------------------------------------

TRANSCRIPT_PATH=lecture transcript file.txt
PDF_PATH=Lecture_17_AI_screenplays.pdf
